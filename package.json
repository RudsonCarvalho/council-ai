{
  "name": "council-ai",
  "version": "1.0.0",
  "description": "A multi-AI decision council for structured debates, consensus, and synthesis",
  "type": "module",
  "scripts": {
    "backend": "node --env-file=.env backend/server.js",
    "frontend": "cd frontend && npm run dev",
    "dev": "concurrently \"npm run backend\" \"npm run frontend\"",
    "install:all": "npm install && cd frontend && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@google/generative-ai": "^0.24.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "multer": "^1.4.5-lts.1",
    "nanoid": "^5.0.7",
    "openai": "^4.77.0",
    "mongoose": "^8.9.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
